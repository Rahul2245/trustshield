# Application
APP_NAME="Unified Trust AI Worker"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
LOG_LEVEL="DEBUG"

# RabbitMQ
AMQP_URL="amqp://guest:guest@localhost:5672/"
QUEUE_NAME="security.threat_analysis_queue"
PREFETCH_COUNT=10

# MongoDB
MONGO_URI="mongodb://localhost:27017/"
DATABASE_NAME="trust_db"
SECURITY_LOG_COLLECTION="security_event_logs"

# Gateway
GATEWAY_WEBHOOK_URL="http://localhost:3000/api/internal/webhook/ai-result"
WEBHOOK_TIMEOUT=5

# Ollama
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3"
OLLAMA_TIMEOUT=45

# Fusion Engine
NLP_WEIGHT=0.65
IF_WEIGHT=0.35

# Risk Thresholds
LOW_RISK_THRESHOLD=50
SHADOW_THRESHOLD=80
HIGH_RISK_THRESHOLD=100

# Worker
MAX_RETRIES=3
RETRY_DELAY=2

# Model Paths
MODEL_DIRECTORY="./local_models"
TFIDF_MODEL_PATH="tfidf.joblib"
NB_MODEL_PATH="nb.joblib"
IF_MODEL_PATH="iforest.joblib"